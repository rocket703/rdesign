---
// src/pages/404.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="404 – Seite nicht gefunden | r³webdesign"
  description="Fehler 404: Diese Seite existiert nicht im System."
>
  <section class="error-section">
    <div class="container">
      
      <div class="content-wrapper">
        <h1 class="glitch" data-text="404">404</h1>
        
        <h2 class="error-title">Systemfehler: Seite nicht gefunden</h2>
        
        <div class="terminal-log">
          <div class="log-line"><span class="cmd">></span> INITIATING_SEARCH... <span class="status error">FAILED</span></div>
          <div class="log-line"><span class="cmd">></span> ERROR_CODE: <span class="value">PAGE_NOT_FOUND</span></div>
          <div class="log-line"><span class="cmd">></span> LOCATION: <span class="value">UNKNOWN_SECTOR</span></div>
          <div class="log-line"><span class="cmd">></span> SUGGESTION: <span class="value">RETURN_TO_BASE</span></div>
        </div>

        <p class="error-desc">
          Die angeforderte URL konnte auf diesem Server nicht gefunden werden. <br>
          Vielleicht wurde sie verschoben, gelöscht oder hat sich im Hyperraum verirrt.
        </p>

        <a href="/" class="back-button">
          Zurück zur Startseite
        </a>
      </div>

    </div>
  </section>
</BaseLayout>

<style>
  /* =========================================
     LAYOUT & HINTERGRUND
     ========================================= */
  .error-section {
    /* Dein gewünschtes Dunkelblau */
    background-color: #0b1120;
    
    min-height: 80vh; /* Füllt fast den ganzen Screen */
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 0;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  /* Optional: Ein sehr subtiler Schein im Hintergrund */
  .error-section::before {
    content: '';
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(16, 185, 129, 0.05) 0%, transparent 70%);
    pointer-events: none;
  }

  .container {
    position: relative;
    z-index: 1;
    padding: 0 1.5rem;
  }

  .content-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 600px;
    margin: 0 auto;
  }

  /* =========================================
     GLITCH EFFECT 404
     ========================================= */
  .glitch {
    font-size: clamp(6rem, 15vw, 10rem);
    font-weight: 900;
    line-height: 1;
    color: #fff;
    position: relative;
    margin-bottom: 1rem;
    letter-spacing: -0.05em;
  }

  .glitch::before,
  .glitch::after {
    content: attr(data-text);
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: #0b1120; /* Gleicher Hintergrund wie Section */
  }

  .glitch::before {
    left: 2px;
    text-shadow: -1px 0 #ff00c1;
    clip: rect(44px, 450px, 56px, 0);
    animation: glitch-anim 5s infinite linear alternate-reverse;
  }

  .glitch::after {
    left: -2px;
    text-shadow: -1px 0 #00fff9;
    clip: rect(44px, 450px, 56px, 0);
    animation: glitch-anim2 5s infinite linear alternate-reverse;
  }

  @keyframes glitch-anim {
    0% { clip: rect(33px, 9999px, 11px, 0); }
    20% { clip: rect(87px, 9999px, 96px, 0); }
    40% { clip: rect(10px, 9999px, 63px, 0); }
    60% { clip: rect(55px, 9999px, 8px, 0); }
    80% { clip: rect(22px, 9999px, 76px, 0); }
    100% { clip: rect(69px, 9999px, 34px, 0); }
  }

  @keyframes glitch-anim2 {
    0% { clip: rect(2px, 9999px, 86px, 0); }
    20% { clip: rect(44px, 9999px, 12px, 0); }
    40% { clip: rect(98px, 9999px, 54px, 0); }
    60% { clip: rect(15px, 9999px, 33px, 0); }
    80% { clip: rect(76px, 9999px, 6px, 0); }
    100% { clip: rect(32px, 9999px, 92px, 0); }
  }

  /* =========================================
     TEXT & TERMINAL
     ========================================= */
  .error-title {
    font-size: 1.5rem;
    color: #fff;
    margin-bottom: 2rem;
  }

  .terminal-log {
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    padding: 1.5rem;
    width: 100%;
    margin-bottom: 2rem;
    text-align: left;
    font-family: 'Courier New', Courier, monospace;
    font-size: 0.9rem;
  }

  .log-line {
    color: #94a3b8;
    margin-bottom: 0.5rem;
    line-height: 1.4;
  }

  .cmd { color: #64748b; margin-right: 0.5rem; }
  .value { color: #fff; }
  .status.error { color: #ef4444; font-weight: bold; }

  .error-desc {
    color: #94a3b8;
    line-height: 1.6;
    margin-bottom: 2.5rem;
  }

  /* =========================================
     BUTTON STYLE
     ========================================= */
  .back-button {
    background: #10b981;
    color: #02040a;
    text-decoration: none;
    padding: 1rem 2rem;
    border-radius: 8px;
    font-weight: 700;
    transition: all 0.3s ease;
    display: inline-block;
  }

  .back-button:hover {
    background: #34d399;
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(16, 185, 129, 0.2);
  }

  @media (max-width: 600px) {
    .terminal-log { font-size: 0.8rem; padding: 1rem; }
  }
</style>