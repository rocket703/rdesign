---
// src/pages/kontakt.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Kontakt – r³webdesign"
  description="Lassen Sie uns gemeinsam Ihr nächstes Web-Projekt realisieren."
>
  <section class="section contact-hero">
    <div class="container">
      <div class="section-head autoShow">
        <span class="eyebrow">Lass uns sprechen</span>
        <h1 class="section-title">Haben Sie ein Projekt <br/> für mich?</h1>
        <div class="title-divider"></div>
        <p class="section-lead">
          Ich freue mich auf neue Herausforderungen. Ob Webseite, App oder komplette digitale Lösung – füllen Sie das Formular aus, und ich melde mich schnellstmöglich.
        </p>
      </div>
    </div>
  </section>

  <section class="contact-form-section">
    <div class="container contact-container">
      <div class="form-wrapper">
        <div id="form-status" class="sr-only" role="status" aria-live="polite" aria-atomic="true"></div>
        <form action="https://api.web3forms.com/submit" method="POST" class="contact-form" novalidate aria-describedby="form-status">
          <input type="hidden" name="access_key" value="d544bd39-97c0-4398-b1b7-3bc12ac7c465">
          <input type="hidden" name="redirect" value="false">
          <input type="hidden" name="from_name" value="Kontaktanfrage r³webdesign">
          <input type="hidden" name="subject" value="Neue Anfrage über Webseite">
          <input type="checkbox" name="botcheck" class="hidden" style="display: none;">

          <div class="form-group float-field">
            <input 
              type="text" 
              id="name" 
              name="name" 
              required 
              placeholder=" "
              autocomplete="name"
              class="form-input"
            >
            <label for="name">Name</label>
            <span class="error-msg" id="name-error">Bitte geben Sie Ihren Namen ein.</span>
          </div>

          <div class="form-group float-field">
            <input 
              type="email" 
              id="email" 
              name="email" 
              required 
              placeholder=" "
              autocomplete="email" 
              class="form-input"
            >
            <label for="email">E-Mail</label>
            <span class="error-msg" id="email-error">Bitte geben Sie eine gültige E-Mail ein.</span>
          </div>

          <div class="form-group float-field float-field--textarea">
            <textarea 
              id="message" 
              name="message" 
              required 
              placeholder=" "
              rows="6"
              class="form-textarea"
            ></textarea>
            <label for="message">Nachricht</label>
            <span class="error-msg" id="message-error">Bitte schreiben Sie eine Nachricht.</span>
          </div>

          <div class="form-group checkbox-group">
            <label class="checkbox-label">
              <input type="checkbox" id="privacy" name="privacy" required class="form-checkbox" aria-describedby="privacy-error">
              <span>Ich stimme der Speicherung meiner Daten zur Kontaktaufnahme zu.</span>
            </label>
            <span class="error-msg" id="privacy-error">Bitte stimmen Sie der Datenschutzerklärung zu.</span>
          </div>

          <button type="submit" class="submit-button">
            <span class="btn-text">Nachricht senden</span>
            <span class="btn-loader"></span>
          </button>
        </form>
      </div>

      <div class="contact-info">
        <div class="info-card">
          <h3>Schnelle Antwort</h3>
          <p>In der Regel antworte ich innerhalb von 24 Stunden auf Ihre Anfrage.</p>
        </div>
        <div class="info-card">
          <h3>Kostenlose Erstberatung</h3>
          <p>Lassen Sie uns klären, was Sie brauchen – unverbindlich und transparent.</p>
        </div>
        <div class="info-card">
          <h3>Individuelle Lösungen</h3>
          <p>Kein Baukasten, sondern maßgeschneiderter Code für Ihr Business.</p>
        </div>
      </div>
    </div>
  </section>

  <div
    id="success-popup"
    class="popup-overlay"
    role="dialog"
    aria-modal="true"
    aria-labelledby="success-popup-title"
    aria-hidden="true"
  >
    <div class="popup-card">
      <div class="popup-icon-wrapper" aria-hidden="true">
        <svg class="check-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
          <path d="M20 6L9 17L4 12" stroke="#10b981" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <h2 id="success-popup-title">Nachricht gesendet!</h2>
      <p>Vielen Dank für Ihre Anfrage. Ich habe Ihre E-Mail erhalten und melde mich in Kürze bei Ihnen.</p>
      <button id="close-popup" class="popup-close-btn">Zurück zur Seite</button>
    </div>
  </div>

</BaseLayout>

<script>
  const form = document.querySelector('.contact-form');
  const popup = document.getElementById('success-popup');
  const closeBtn = document.getElementById('close-popup');
  const submitBtn = document.querySelector('.submit-button');
  const btnText = document.querySelector('.btn-text');
  const popupIcon = document.querySelector('.popup-icon-wrapper');
  const formStatus = document.getElementById('form-status');
  const inputs = document.querySelectorAll('.form-input, .form-textarea, .form-checkbox');
  let popupReturnFocus = null;

  const fieldErrorId = {
    name: 'name-error',
    email: 'email-error',
    message: 'message-error',
    privacy: 'privacy-error',
  };

  const setFormStatus = (message) => {
    if (formStatus) formStatus.textContent = message;
  };

  const spawnRipple = (e) => {
    if (!submitBtn || submitBtn.disabled) return;
    const rect = submitBtn.getBoundingClientRect();
    const ripple = document.createElement('span');
    ripple.className = 'btn-ripple';
    const size = Math.max(rect.width, rect.height);
    ripple.style.width = ripple.style.height = size + 'px';
    ripple.style.left = (e.clientX - rect.left - size / 2) + 'px';
    ripple.style.top = (e.clientY - rect.top - size / 2) + 'px';
    submitBtn.appendChild(ripple);
    ripple.addEventListener('animationend', () => ripple.remove());
  };

  submitBtn?.addEventListener('pointerdown', spawnRipple);

  const clearFieldError = (input) => {
    const group = input.closest('.form-group');
    group?.classList.remove('error');
    input.removeAttribute('aria-invalid');
    const errorId = fieldErrorId[input.name] || fieldErrorId[input.id];
    if (errorId && input.getAttribute('aria-describedby') === errorId) {
      input.removeAttribute('aria-describedby');
    }
  };

  const validateField = (input) => {
    const group = input.closest('.form-group');
    const errorId = fieldErrorId[input.name] || fieldErrorId[input.id];
    if (!input.checkValidity()) {
      group?.classList.add('error');
      input.setAttribute('aria-invalid', 'true');
      if (errorId) input.setAttribute('aria-describedby', errorId);
      return false;
    }
    clearFieldError(input);
    return true;
  };

  inputs.forEach((input) => {
    input.addEventListener('input', () => clearFieldError(input));
    input.addEventListener('change', () => clearFieldError(input));
  });

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      let isValid = true;
      
      // Prüfe alle Felder
      inputs.forEach(input => {
        if (!validateField(input)) {
          isValid = false;
        }
      });

      if (!isValid) {
        form.classList.add('shake');
        setTimeout(() => form.classList.remove('shake'), 500);
        setFormStatus('Bitte prüfen Sie die markierten Felder.');
        const firstInvalid = form.querySelector('[aria-invalid="true"]');
        firstInvalid?.focus();
        return;
      }

      setFormStatus('');

      // Start Loading State
      submitBtn.classList.add('loading');
      btnText.innerText = 'Wird gesendet...';
      submitBtn.disabled = true;

      const formData = new FormData(form);

      try {
        const response = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          body: formData
        });

        if (response.ok) {
          form.reset();
          inputs.forEach((input) => clearFieldError(input));
          openPopup();
          popupIcon?.classList.remove('success-pulse');
          void popupIcon?.offsetWidth;
          popupIcon?.classList.add('success-pulse');
          setFormStatus('Nachricht erfolgreich gesendet.');
        } else {
          setFormStatus('Ups, da lief etwas schief. Bitte versuchen Sie es später erneut.');
        }
      } catch (error) {
        console.error(error);
        setFormStatus('Netzwerkfehler. Bitte prüfen Sie Ihre Verbindung.');
      } finally {
        // Reset Button State
        submitBtn.classList.remove('loading');
        btnText.innerText = 'Nachricht senden';
        submitBtn.disabled = false;
      }
    });
  }

  const openPopup = () => {
    if (!popup) return;
    popupReturnFocus = document.activeElement;
    popup.classList.add('is-visible');
    popup.setAttribute('aria-hidden', 'false');
    if ('inert' in popup) popup.inert = false;
    closeBtn?.focus();
  };

  const closePopup = () => {
    if (!popup) return;
    popup.classList.remove('is-visible');
    popup.setAttribute('aria-hidden', 'true');
    if ('inert' in popup) popup.inert = true;
    if (popupReturnFocus && typeof popupReturnFocus.focus === 'function') {
      popupReturnFocus.focus();
    }
    popupReturnFocus = null;
  };

  if (popup && 'inert' in popup) popup.inert = true;

  if (closeBtn) closeBtn.addEventListener('click', closePopup);
  if (popup) {
    popup.addEventListener('click', (e) => {
      if (e.target === popup) closePopup();
    });
    popup.addEventListener('keydown', (e) => {
      if (e.key !== 'Tab' || !popup.classList.contains('is-visible')) return;
      const focusable = popup.querySelectorAll(
        'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])'
      );
      if (focusable.length === 0) return;
      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    });
  }
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && popup?.classList.contains('is-visible')) closePopup();
  });
</script>

<style>
  /* =========================================
     1. HERO & GENERAL
     ========================================= */
  .contact-hero {
    background: radial-gradient(circle at top, #1e293b 0%, #030712 100%);
    padding: 10rem 0 6rem 0;
    text-align: center;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-head { margin: 0 auto 3rem auto; max-width: 800px; }
  .eyebrow { color: #10b981; text-transform: uppercase; letter-spacing: 2px; font-weight: 800; font-size: 0.85rem; display: block; margin-bottom: 1rem; }
  .section-title { font-size: clamp(2.5rem, 6vw, 4rem); color: #fff; font-weight: 900; line-height: 1.1; margin-bottom: 1.5rem; }
  .title-divider { width: 60px; height: 4px; background: #10b981; margin: 2rem auto; border-radius: 2px; }
  .section-lead { color: #94a3b8; font-size: 1.2rem; line-height: 1.6; }

  /* =========================================
     2. FORM LAYOUT & STYLING
     ========================================= */
  .contact-form-section {
    background-color: #0b1120;
    padding-bottom: 8rem;
  }

  .contact-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
  }

  @media (min-width: 900px) {
    .contact-container {
      grid-template-columns: 1.5fr 1fr; /* Mehr Platz fürs Formular */
      gap: 5rem;
    }
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    background: rgba(255,255,255,0.02);
    padding: 2.5rem;
    border-radius: 24px;
    border: 1px solid rgba(255,255,255,0.05);
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    position: relative;
  }

  /* Floating Labels */
  .float-field {
    position: relative;
    gap: 0;
  }

  .float-field label {
    position: absolute;
    left: 1.25rem;
    top: 50%;
    transform: translateY(-50%);
    color: #64748b;
    font-size: 1rem;
    font-weight: 500;
    pointer-events: none;
    transition: top 0.22s ease, transform 0.22s ease, font-size 0.22s ease, color 0.22s ease;
  }

  .float-field--textarea label {
    top: 1.25rem;
    transform: none;
  }

  .float-field .form-input,
  .float-field .form-textarea {
    padding-top: 1.45rem;
    padding-bottom: 0.75rem;
  }

  .float-field .form-input:focus + label,
  .float-field .form-input:not(:placeholder-shown) + label,
  .float-field .form-textarea:focus + label,
  .float-field .form-textarea:not(:placeholder-shown) + label {
    top: 0.55rem;
    transform: none;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #10b981;
  }

  .float-field--textarea .form-textarea:focus + label,
  .float-field--textarea .form-textarea:not(:placeholder-shown) + label {
    top: 0.45rem;
  }

  .checkbox-group label {
    position: static;
    transform: none;
    pointer-events: auto;
  }

  .form-input, .form-textarea {
    background: #0b1120;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    padding: 1rem 1.25rem;
    color: #fff;
    font-family: inherit;
    font-size: 1rem;
    transition: all 0.3s ease;
  }

  .form-input:focus, .form-textarea:focus {
    outline: none;
    border-color: #10b981;
    box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.15);
  }

  /* Validierungs-Styles */
  .error-msg {
    color: #ef4444;
    font-size: 0.85rem;
    margin-top: 0.25rem;
    margin-left: 0.25rem;
    opacity: 0;
    transform: translateY(-5px);
    transition: all 0.3s ease;
    height: 0;
    overflow: hidden;
  }

  .form-group.error .form-input,
  .form-group.error .form-textarea,
  .form-group.error .form-checkbox {
    border-color: #ef4444;
    background: rgba(239, 68, 68, 0.05);
  }

  .form-group.error .error-msg {
    opacity: 1;
    transform: translateY(0);
    height: auto;
    margin-top: 0.5rem;
  }

  /* Shake Animation für ungültiges Formular */
  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-5px); }
    75% { transform: translateX(5px); }
  }
  .shake { animation: shake 0.4s ease-in-out; }

  /* Checkbox */
  .checkbox-label {
    display: flex;
    gap: 0.75rem;
    cursor: pointer;
    color: #94a3b8;
    font-size: 0.9rem;
    line-height: 1.5;
  }
  .form-checkbox {
    width: 20px; height: 20px;
    accent-color: #10b981;
    cursor: pointer;
  }

  /* Submit Button mit Loading State + Ripple */
  .submit-button {
    background: #10b981;
    color: #000;
    border: none;
    padding: 1.25rem;
    font-size: 1rem;
    font-weight: 800;
    border-radius: 12px;
    cursor: pointer;
    transition: all 0.3s ease;
    margin-top: 1rem;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.5rem;
    position: relative;
    overflow: hidden;
  }

  .btn-ripple {
    position: absolute;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.35);
    transform: scale(0);
    animation: btnRipple 0.65s ease-out forwards;
    pointer-events: none;
  }

  @keyframes btnRipple {
    to {
      transform: scale(2.8);
      opacity: 0;
    }
  }

  .submit-button:hover:not(:disabled) {
    background: #34d399;
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(16, 185, 129, 0.2);
  }

  .submit-button:disabled {
    background: #064e3b;
    color: #6ee7b7;
    cursor: not-allowed;
    transform: none;
  }

  /* =========================================
     3. INFO CARDS
     ========================================= */
  .contact-info { display: flex; flex-direction: column; gap: 1.5rem; }
  .info-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    padding: 1.5rem;
    border-radius: 16px;
    transition: transform 0.3s ease;
  }
  .info-card:hover { transform: translateX(5px); border-color: #10b981; }
  .info-card h3 { color: #fff; margin-bottom: 0.5rem; font-size: 1.1rem; }
  .info-card p { color: #94a3b8; font-size: 0.95rem; line-height: 1.6; }

  /* =========================================
     4. PREMIUM POPUP (Overlay)
     ========================================= */
  .popup-overlay {
    position: fixed;
    top: 0; left: 0; width: 100%; height: 100%;
    background: rgba(0,0,0,0.85);
    backdrop-filter: blur(8px);
    z-index: 9999; /* Über alles legen */
    display: flex;
    justify-content: center;
    align-items: center;
    opacity: 0;
    visibility: hidden;
    transition: all 0.4s ease;
    padding: 1.5rem;
  }

  .popup-overlay.is-visible {
    opacity: 1;
    visibility: visible;
  }

  .popup-card {
    background: #0f172a;
    border: 1px solid rgba(255,255,255,0.1);
    padding: 3rem 2.5rem;
    border-radius: 24px;
    text-align: center;
    max-width: 450px;
    width: 100%;
    transform: scale(0.9);
    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    position: relative;
    overflow: hidden;
  }

  /* Leuchtender Rand Effekt */
  .popup-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; height: 4px;
    background: linear-gradient(90deg, #10b981, #34d399);
  }

  .popup-overlay.is-visible .popup-card {
    transform: scale(1);
  }

  .popup-icon-wrapper {
    width: 80px; height: 80px;
    background: rgba(16, 185, 129, 0.1);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.5rem auto;
  }

  .popup-icon-wrapper.success-pulse {
    animation: successRing 0.75s ease-out;
  }

  @keyframes successRing {
    0% {
      box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.55);
      transform: scale(1);
    }
    40% {
      transform: scale(1.06);
    }
    100% {
      box-shadow: 0 0 0 22px rgba(16, 185, 129, 0);
      transform: scale(1);
    }
  }

  .check-icon { width: 40px; height: 40px; }

  .popup-card h2 { color: #fff; font-size: 1.75rem; font-weight: 800; margin-bottom: 1rem; }
  .popup-card p { color: #94a3b8; line-height: 1.6; margin-bottom: 2rem; }

  .popup-close-btn {
    background: #10b981;
    color: #000;
    border: none;
    padding: 1rem 2rem;
    border-radius: 12px;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.3s ease;
    width: 100%;
  }

  .popup-close-btn:hover { background: #34d399; transform: translateY(-2px); }

  /* Mobile Adjustments */
  @media (max-width: 600px) {
    .section-title br { display: none; }
    .contact-form { padding: 1.5rem; }
  }
</style>