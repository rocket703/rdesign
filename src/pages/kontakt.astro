---
import BaseLayout from '../layouts/BaseLayout.astro';
import LegalPageShell from '../components/LegalPageShell.astro';
import { schemaGraph, webPageSchema } from '../lib/seo';

const pageTitle = 'Kontakt – Webdesign Magdeburg | r³webdesign';
const pageDescription =
  'Projektanfrage für Webdesign, Homepage oder Web-App in Magdeburg. Schreib mir dein Vorhaben – ich melde mich zeitnah zurück.';
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  jsonLd={schemaGraph([
    webPageSchema({
      name: pageTitle,
      description: pageDescription,
      pathname: Astro.url.pathname,
      site: Astro.site,
    }),
  ])}
>
  <LegalPageShell
    wide
    eyebrow="Lass uns sprechen"
    title="Projekt anfragen"
    lead="Ob Webseite, App oder komplette digitale Lösung — beschreib kurz dein Vorhaben, ich melde mich zeitnah."
  >
    <div class="contact-layout">
      <article class="legal-block legal-block--form autoShow">
        <p class="legal-block__path">
          <span class="legal-block__prompt">&gt;_</span> contact.send
        </p>
        <h2 class="legal-block__title">Nachricht schreiben</h2>

        <div id="form-status" class="sr-only" role="status" aria-live="polite" aria-atomic="true"></div>
        <form
          action="https://api.web3forms.com/submit"
          method="POST"
          class="contact-form"
          novalidate
          aria-describedby="form-status"
        >
          <input type="hidden" name="access_key" value="d544bd39-97c0-4398-b1b7-3bc12ac7c465" />
          <input type="hidden" name="redirect" value="false" />
          <input type="hidden" name="from_name" value="Kontaktanfrage r³webdesign" />
          <input type="hidden" name="subject" value="Neue Anfrage über Webseite" />
          <input type="checkbox" name="botcheck" class="hidden" style="display: none;" />

          <div class="form-group float-field">
            <input
              type="text"
              id="name"
              name="name"
              required
              placeholder=" "
              autocomplete="name"
              class="form-input"
            />
            <label for="name">Name</label>
            <span class="error-msg" id="name-error">Bitte geben Sie Ihren Namen ein.</span>
          </div>

          <div class="form-group float-field">
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder=" "
              autocomplete="email"
              class="form-input"
            />
            <label for="email">E-Mail</label>
            <span class="error-msg" id="email-error">Bitte geben Sie eine gültige E-Mail ein.</span>
          </div>

          <div class="form-group float-field float-field--textarea">
            <textarea
              id="message"
              name="message"
              required
              placeholder=" "
              rows="6"
              class="form-textarea"
            ></textarea>
            <label for="message">Nachricht</label>
            <span class="error-msg" id="message-error">Bitte schreiben Sie eine Nachricht.</span>
          </div>

          <div class="form-group checkbox-group">
            <label class="checkbox-label">
              <input
                type="checkbox"
                id="privacy"
                name="privacy"
                required
                class="form-checkbox"
                aria-describedby="privacy-error"
              />
              <span>
                Ich habe die <a href="/datenschutz/" class="legal-link">Datenschutzerklärung</a> gelesen und stimme der Verarbeitung meiner Angaben zur Kontaktaufnahme zu.
              </span>
            </label>
            <span class="error-msg" id="privacy-error">Bitte bestätigen Sie die Datenschutzerklärung.</span>
          </div>

          <button type="submit" class="submit-button">
            <span class="btn-text">Nachricht senden</span>
            <span class="btn-loader"></span>
          </button>
        </form>
      </article>

      <aside class="contact-aside">
        <article class="legal-block autoShow">
          <p class="legal-block__path">
            <span class="legal-block__prompt">&gt;_</span> contact.response
          </p>
          <h2 class="legal-block__title">Schnelle Antwort</h2>
          <div class="legal-block__body">
            <p>In der Regel antworte ich innerhalb von 24 Stunden auf deine Anfrage.</p>
          </div>
        </article>

        <article class="legal-block autoShow">
          <p class="legal-block__path">
            <span class="legal-block__prompt">&gt;_</span> contact.briefing
          </p>
          <h2 class="legal-block__title">Kostenlose Erstberatung</h2>
          <div class="legal-block__body">
            <p>Lassen wir klären, was du brauchst — unverbindlich und transparent.</p>
          </div>
        </article>

        <article class="legal-block autoShow">
          <p class="legal-block__path">
            <span class="legal-block__prompt">&gt;_</span> contact.custom
          </p>
          <h2 class="legal-block__title">Individuelle Lösungen</h2>
          <div class="legal-block__body">
            <p>Kein Baukasten, sondern maßgeschneiderter Code für dein Vorhaben.</p>
          </div>
        </article>
      </aside>
    </div>
  </LegalPageShell>

  <div
    id="success-popup"
    class="contact-popup"
    role="dialog"
    aria-modal="true"
    aria-labelledby="success-popup-title"
    aria-hidden="true"
  >
    <div class="contact-popup__card">
      <div class="contact-popup__icon" aria-hidden="true">
        <svg class="check-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" width="40" height="40" aria-hidden="true" focusable="false">
          <path d="M20 6L9 17L4 12" stroke="#10b981" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <h2 id="success-popup-title">Nachricht gesendet!</h2>
      <p>Vielen Dank für deine Anfrage. Ich habe deine Nachricht erhalten und melde mich in Kürze.</p>
      <button type="button" id="close-popup" class="contact-popup__close">Zurück zur Seite</button>
    </div>
  </div>
</BaseLayout>

<script>
  const form = document.querySelector('.contact-form');
  const popup = document.getElementById('success-popup');
  const closeBtn = document.getElementById('close-popup');
  const submitBtn = document.querySelector('.submit-button');
  const btnText = document.querySelector('.btn-text');
  const popupIcon = document.querySelector('.contact-popup__icon');
  const formStatus = document.getElementById('form-status');
  const inputs = document.querySelectorAll('.form-input, .form-textarea, .form-checkbox');
  let popupReturnFocus = null;

  const fieldErrorId = {
    name: 'name-error',
    email: 'email-error',
    message: 'message-error',
    privacy: 'privacy-error',
  };

  const setFormStatus = (message) => {
    if (formStatus) formStatus.textContent = message;
  };

  const spawnRipple = (e) => {
    if (!submitBtn || submitBtn.disabled) return;
    const rect = submitBtn.getBoundingClientRect();
    const ripple = document.createElement('span');
    ripple.className = 'btn-ripple';
    const size = Math.max(rect.width, rect.height);
    ripple.style.width = ripple.style.height = size + 'px';
    ripple.style.left = (e.clientX - rect.left - size / 2) + 'px';
    ripple.style.top = (e.clientY - rect.top - size / 2) + 'px';
    submitBtn.appendChild(ripple);
    ripple.addEventListener('animationend', () => ripple.remove());
  };

  submitBtn?.addEventListener('pointerdown', spawnRipple);

  const clearFieldError = (input) => {
    const group = input.closest('.form-group');
    group?.classList.remove('error');
    input.removeAttribute('aria-invalid');
    const errorId = fieldErrorId[input.name] || fieldErrorId[input.id];
    if (errorId && input.getAttribute('aria-describedby') === errorId) {
      input.removeAttribute('aria-describedby');
    }
  };

  const validateField = (input) => {
    const group = input.closest('.form-group');
    const errorId = fieldErrorId[input.name] || fieldErrorId[input.id];
    if (!input.checkValidity()) {
      group?.classList.add('error');
      input.setAttribute('aria-invalid', 'true');
      if (errorId) input.setAttribute('aria-describedby', errorId);
      return false;
    }
    clearFieldError(input);
    return true;
  };

  inputs.forEach((input) => {
    input.addEventListener('input', () => clearFieldError(input));
    input.addEventListener('change', () => clearFieldError(input));
  });

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      let isValid = true;
      inputs.forEach((input) => {
        if (!validateField(input)) isValid = false;
      });

      if (!isValid) {
        form.classList.add('shake');
        setTimeout(() => form.classList.remove('shake'), 500);
        setFormStatus('Bitte prüfen Sie die markierten Felder.');
        const firstInvalid = form.querySelector('[aria-invalid="true"]');
        firstInvalid?.focus();
        return;
      }

      setFormStatus('');
      submitBtn.classList.add('loading');
      btnText.textContent = 'Wird gesendet...';
      submitBtn.disabled = true;

      const formData = new FormData(form);

      try {
        const response = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          body: formData,
        });
        const data = await response.json();

        if (response.ok && data.success) {
          form.reset();
          inputs.forEach((input) => clearFieldError(input));
          setFormStatus('Nachricht erfolgreich gesendet.');
          popupReturnFocus = submitBtn;
          popup?.classList.add('is-visible');
          popup?.setAttribute('aria-hidden', 'false');
          popupIcon?.classList.add('success-pulse');
          setTimeout(() => popupIcon?.classList.remove('success-pulse'), 800);
          closeBtn?.focus();
        } else {
          throw new Error(data.message || 'Senden fehlgeschlagen');
        }
      } catch (error) {
        setFormStatus('Senden fehlgeschlagen. Bitte versuchen Sie es später erneut oder schreiben Sie direkt per E-Mail.');
        console.error(error);
      } finally {
        submitBtn.classList.remove('loading');
        btnText.textContent = 'Nachricht senden';
        submitBtn.disabled = false;
      }
    });
  }

  const closePopup = () => {
    popup?.classList.remove('is-visible');
    popup?.setAttribute('aria-hidden', 'true');
    popupReturnFocus?.focus();
    popupReturnFocus = null;
  };

  closeBtn?.addEventListener('click', closePopup);
  popup?.addEventListener('click', (e) => {
    if (e.target === popup) closePopup();
  });

  if (popup) {
    popup.addEventListener('keydown', (e) => {
      if (e.key !== 'Tab') return;
      const focusable = popup.querySelectorAll(
        'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])'
      );
      if (focusable.length === 0) return;
      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    });
  }

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && popup?.classList.contains('is-visible')) closePopup();
  });
</script>

<style>
  .btn-ripple {
    position: absolute;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.35);
    transform: scale(0);
    animation: btnRipple 0.65s ease-out forwards;
    pointer-events: none;
  }

  @keyframes btnRipple {
    to {
      transform: scale(2.8);
      opacity: 0;
    }
  }

  .contact-popup__icon.success-pulse {
    animation: successRing 0.75s ease-out;
  }

  @keyframes successRing {
    0% {
      box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.55);
      transform: scale(1);
    }
    40% {
      transform: scale(1.06);
    }
    100% {
      box-shadow: 0 0 0 22px rgba(16, 185, 129, 0);
      transform: scale(1);
    }
  }
</style>
