---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="404 – Seite nicht gefunden | r³webdesign"
  description="Fehler 404: Diese Seite existiert nicht im System."
  noindex={true}
>
  <article class="error-view">
    <div class="main-container">
      <nav class="error-nav" aria-label="Seitennavigation">
        <a href="/" class="error-back">
          <span class="error-back__prompt" aria-hidden="true">&gt;_</span>
          <span>zurück.start</span>
        </a>
      </nav>

      <header class="error-hero">
        <p class="project-path error-hero__path">
          <span class="project-prompt">&gt;_</span>
          <span>err.404</span>
        </p>
        <p class="error-code-label" aria-hidden="true">
          <span class="error-code-label__num">404</span>
        </p>
        <div class="title-divider"></div>
        <h1 class="section-title error-hero__title">Seite nicht gefunden</h1>
        <p class="section-lead error-hero__lead">
          Die angeforderte URL gibt es auf diesem Server nicht — verschoben, gelöscht oder nie gebaut.
        </p>
      </header>

      <section class="error-panel" aria-label="Terminal-Ausgabe">
        <p class="error-panel__path">
          <span class="project-prompt">&gt;_</span>
          <span>shell</span>
        </p>
        <div class="error-terminal">
          <p class="error-terminal__line">
            <span class="error-terminal__prompt">&gt;</span>
            <span> cd </span>
            <code class="error-terminal__path" id="error-request-path">/…</code>
          </p>
          <p class="error-terminal__line error-terminal__line--fail">
            <span class="error-terminal__prompt">&gt;</span>
            <span> bash: cd: Pfad nicht gefunden (exit 1)</span>
          </p>
          <p class="error-terminal__line">
            <span class="error-terminal__prompt">&gt;</span>
            <span> curl -I </span>
            <code class="error-terminal__path" id="error-request-url">…</code>
          </p>
          <p class="error-terminal__line">
            <span class="error-terminal__prompt">&gt;</span>
            <span> HTTP/1.1 </span>
            <span class="error-terminal__status">404 Not Found</span>
          </p>
          <p class="error-terminal__line error-terminal__line--hint">
            <span class="error-terminal__prompt">&gt;</span>
            <span> hint: zurück zu / oder /projekte/ probieren</span>
          </p>
        </div>
      </section>

      <div class="error-actions">
        <a href="/" class="error-cta error-cta--primary">
          <span class="error-cta__prompt" aria-hidden="true">&gt;</span>
          Startseite
        </a>
        <a href="/projekte/" class="error-cta error-cta--ghost">
          <span class="error-cta__prompt" aria-hidden="true">&gt;</span>
          Projekte
        </a>
        <a href="/kontakt/" class="error-cta error-cta--ghost">
          <span class="error-cta__prompt" aria-hidden="true">&gt;</span>
          Kontakt
        </a>
      </div>
    </div>
  </article>
</BaseLayout>

<script is:inline>
  (function () {
    var pathEl = document.getElementById('error-request-path');
    var urlEl = document.getElementById('error-request-url');
    if (!pathEl || !urlEl) return;
    var path = window.location.pathname || '/';
    var search = window.location.search || '';
    pathEl.textContent = path + search;
    urlEl.textContent = window.location.origin + path + search;
  })();
</script>

<style>
  .error-view {
    background-color: #0b1120;
    color: #fff;
    min-height: calc(100vh - 4rem);
    padding: clamp(1.5rem, 4vw, 2.5rem) 0 clamp(5rem, 10vw, 8rem);
  }

  .main-container {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .error-nav {
    margin-bottom: clamp(1.5rem, 4vw, 2.5rem);
  }

  .error-back {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: ui-monospace, 'Cascadia Code', monospace;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: lowercase;
    text-decoration: none;
    color: #94a3b8;
    transition: color 0.2s ease;
  }

  .error-back__prompt {
    color: #10b981;
    font-weight: 700;
  }

  .error-back:hover {
    color: #ecfdf5;
  }

  .error-hero {
    text-align: center;
    margin-bottom: clamp(2rem, 5vw, 3rem);
  }

  .error-hero__path {
    justify-content: center;
    margin-bottom: 1rem;
  }

  .error-code-label {
    margin: 0 0 0.25rem;
    line-height: 1;
  }

  .error-code-label__num {
    display: inline-block;
    font-size: clamp(4.5rem, 18vw, 8rem);
    font-weight: 900;
    letter-spacing: -0.06em;
    line-height: 0.95;
    background: linear-gradient(180deg, #f8fafc 0%, #6ee7b7 55%, #10b981 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    filter: drop-shadow(0 8px 32px rgba(16, 185, 129, 0.12));
  }

  .error-hero__title {
    font-size: clamp(1.35rem, 4vw, 2rem);
    margin: 0;
  }

  .error-hero__lead {
    margin-top: 0.75rem;
    max-width: 42ch;
    margin-left: auto;
    margin-right: auto;
  }

  .error-panel {
    position: relative;
    margin-bottom: clamp(2rem, 5vw, 2.75rem);
    padding: clamp(1.25rem, 3vw, 1.75rem);
    border-radius: 14px;
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.06) 0%, rgba(255, 255, 255, 0.02) 42%, transparent 100%),
      rgba(11, 17, 32, 0.9);
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.06),
      0 18px 40px rgba(0, 0, 0, 0.35);
    text-align: left;
  }

  .error-panel::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    border-radius: 14px 14px 0 0;
    background: linear-gradient(90deg, var(--accent-lime) 0%, #10b981 35%, #ef4444 70%, transparent 100%);
    opacity: 0.75;
    pointer-events: none;
  }

  .error-panel__path {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    margin: 0 0 1rem;
    font-family: ui-monospace, monospace;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: lowercase;
    color: #64748b;
  }

  .error-terminal {
    margin: 0;
    font-family: ui-monospace, 'Cascadia Code', monospace;
    font-size: clamp(0.72rem, 2vw, 0.82rem);
    line-height: 1.65;
  }

  .error-terminal__line {
    margin: 0 0 0.45rem;
    color: #94a3b8;
    word-break: break-word;
  }

  .error-terminal__line:last-child {
    margin-bottom: 0;
  }

  .error-terminal__line--fail {
    color: #fca5a5;
  }

  .error-terminal__line--hint {
    color: #64748b;
    margin-top: 0.65rem;
    padding-top: 0.65rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .error-terminal__prompt {
    color: #10b981;
    font-weight: 700;
    margin-right: 0.35rem;
  }

  .error-terminal__path {
    color: #e2e8f0;
    font-size: inherit;
  }

  .error-terminal__status {
    color: #f87171;
    font-weight: 700;
  }

  .error-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
  }

  .error-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 1.25rem;
    border-radius: 10px;
    font-family: ui-monospace, monospace;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    text-transform: lowercase;
    text-decoration: none;
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .error-cta__prompt {
    color: #34d399;
  }

  .error-cta--primary {
    color: #ecfdf5;
    background: linear-gradient(145deg, rgba(16, 185, 129, 0.22) 0%, rgba(16, 185, 129, 0.08) 100%);
    border: 1px solid rgba(16, 185, 129, 0.35);
  }

  .error-cta--primary:hover {
    transform: translateY(-2px);
    border-color: rgba(52, 211, 153, 0.55);
    box-shadow: 0 8px 24px rgba(16, 185, 129, 0.15);
  }

  .error-cta--ghost {
    color: #94a3b8;
    background: rgba(0, 0, 0, 0.25);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .error-cta--ghost .error-cta__prompt {
    color: #10b981;
  }

  .error-cta--ghost:hover {
    color: #ecfdf5;
    border-color: rgba(16, 185, 129, 0.25);
    transform: translateY(-2px);
  }

  @media (prefers-reduced-motion: reduce) {
    .error-cta--primary:hover,
    .error-cta--ghost:hover {
      transform: none;
    }
  }
</style>
