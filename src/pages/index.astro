  /* --- TECH STACK WÜRFEL --- */
  .dynamic-cube {
    --cube-size: 5.5rem;
    --cube-half: calc(var(--cube-size) / 2);
    min-height: 300px;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    justify-content: flex-start;
    gap: 1.25rem;
    perspective: 1100px;
    overflow: hidden;
    cursor: default;
    position: relative;
    isolation: isolate;
  }

  .dynamic-cube::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    border-radius: 15px 15px 0 0;
    background: linear-gradient(90deg, #10b981 0%, #38bdf8 55%, transparent 100%);
    opacity: 0.65;
    pointer-events: none;
    z-index: 3;
  }

  .dynamic-cube .skill-card__path {
    margin-bottom: 0;
    position: relative;
    z-index: 2;
  }

  .cube-scene {
    position: relative;
    flex: 1;
    display: grid;
    place-items: center;
    min-height: 11rem;
    margin-top: 0.25rem;
  }

  .cube-scene__aura {
    position: absolute;
    width: 11rem;
    height: 11rem;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(16, 185, 129, 0.22) 0%,
      rgba(56, 189, 248, 0.08) 42%,
      transparent 72%
    );
    filter: blur(10px);
    animation: cubeAuraPulse 5s ease-in-out infinite;
    pointer-events: none;
  }

  .cube-scene__orbit {
    position: absolute;
    width: 9.5rem;
    height: 9.5rem;
    border-radius: 50%;
    border: 1px dashed rgba(16, 185, 129, 0.28);
    animation: cubeOrbitSpin 22s linear infinite;
    pointer-events: none;
  }

  .cube-scene__orbit::after {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #34d399;
    box-shadow: 0 0 10px rgba(16, 185, 129, 0.75);
    transform: translate(-50%, -50%);
  }

  .cube-scene__orbit--inner {
    width: 7.25rem;
    height: 7.25rem;
    border-style: solid;
    border-color: rgba(56, 189, 248, 0.14);
    animation-direction: reverse;
    animation-duration: 14s;
    opacity: 0.85;
  }

  .cube-scene__orbit--inner::after {
    top: auto;
    bottom: 0;
    background: #38bdf8;
    box-shadow: 0 0 10px rgba(56, 189, 248, 0.65);
    width: 5px;
    height: 5px;
    transform: translate(-50%, 50%);
  }

  .cube-wrapper {
    width: var(--cube-size);
    height: var(--cube-size);
    transform-style: preserve-3d;
    animation: cubeTumbleY 7s linear infinite;
    will-change: transform;
  }

  .cube {
    position: relative;
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
    animation: cubeTumbleX 5s linear infinite;
    will-change: transform;
  }

  .face {
    position: absolute;
    width: var(--cube-size);
    height: var(--cube-size);
    display: flex;
    align-items: center;
    justify-content: center;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    border-radius: 0;
    border: 1px solid rgba(16, 185, 129, 0.5);
    background: rgba(8, 15, 28, 0.92);
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.04);
  }

  .face span {
    font-family: ui-monospace, 'Cascadia Code', monospace;
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #f8fafc;
    text-shadow: 0 0 12px rgba(16, 185, 129, 0.3);
    padding: 0 0.15rem;
  }

  .face--front {
    background: linear-gradient(145deg, rgba(16, 185, 129, 0.35), rgba(16, 185, 129, 0.08));
    border-color: rgba(52, 211, 153, 0.55);
    transform: translateZ(var(--cube-half));
  }

  .face--back {
    background: linear-gradient(145deg, rgba(139, 92, 246, 0.32), rgba(139, 92, 246, 0.06));
    border-color: rgba(167, 139, 250, 0.45);
    transform: rotateY(180deg) translateZ(var(--cube-half));
  }

  .face--back span { text-shadow: 0 0 16px rgba(167, 139, 250, 0.45); }

  .face--right {
    background: linear-gradient(145deg, rgba(56, 189, 248, 0.28), rgba(56, 189, 248, 0.06));
    border-color: rgba(56, 189, 248, 0.45);
    transform: rotateY(90deg) translateZ(var(--cube-half));
  }

  .face--right span { text-shadow: 0 0 16px rgba(56, 189, 248, 0.45); }

  .face--left {
    background: linear-gradient(145deg, rgba(251, 191, 36, 0.22), rgba(251, 191, 36, 0.05));
    border-color: rgba(251, 191, 36, 0.4);
    transform: rotateY(-90deg) translateZ(var(--cube-half));
  }

  .face--left span { text-shadow: 0 0 14px rgba(251, 191, 36, 0.35); }

  .face--top {
    background: linear-gradient(145deg, rgba(52, 211, 153, 0.25), rgba(16, 185, 129, 0.06));
    border-color: rgba(52, 211, 153, 0.4);
    transform: rotateX(90deg) translateZ(var(--cube-half));
  }

  .face--bottom {
    background: linear-gradient(145deg, rgba(99, 102, 241, 0.28), rgba(99, 102, 241, 0.06));
    border-color: rgba(129, 140, 248, 0.45);
    transform: rotateX(-90deg) translateZ(var(--cube-half));
  }

  .face--bottom span { text-shadow: 0 0 14px rgba(129, 140, 248, 0.4); }

  @keyframes cubeTumbleY {
    from { transform: rotateY(0deg); }
    to { transform: rotateY(360deg); }
  }

  @keyframes cubeTumbleX {
    from { transform: rotateX(0deg); }
    to { transform: rotateX(360deg); }
  }

  @keyframes cubeOrbitSpin {
    0% { transform: rotateZ(0deg); }
    100% { transform: rotateZ(360deg); }
  }

  @keyframes cubeAuraPulse {
    0%, 100% { opacity: 0.75; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.05); }
  }

  @media (max-width: 768px) {
    .dynamic-cube {
      --cube-size: 4.75rem;
    }

    .cube-scene {
      min-height: 9.5rem;
    }

    .cube-scene__aura {
      width: 9rem;
      height: 9rem;
    }

    .cube-scene__orbit {
      width: 8rem;
      height: 8rem;
    }

    .cube-scene__orbit--inner {
      width: 6.25rem;
      height: 6.25rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cube-wrapper,
    .cube,
    .cube-scene__orbit,
    .cube-scene__aura {
      animation: none !important;
    }

    .cube-wrapper {
      transform: rotateY(24deg);
    }

    .cube {
      transform: rotateX(-16deg);
    }
  }

