<script define:vars={{ codeMobile, codeDesktop }}>
  (function () {
    const codeEl = document.getElementById('dev-showcase-code');
    const cursorEl = document.getElementById('dev-code-cursor');
    const codeArea = document.getElementById('dev-code-area');
    if (!codeEl || !codeArea) return;

    const desktopMq = window.matchMedia('(min-width: 1024px)');
    const reducedMq = window.matchMedia('(prefers-reduced-motion: reduce)');

    const highlight = (src) => {
      const esc = (s) =>
        s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
      let html = esc(src);
      html = html.replace(/(\/\*\*[\s\S]*?\*\/|\/\/[^\n]*)/g, '<span class="tok-cm">$1</span>');
      html = html.replace(/('(?:\\.|[^'\\])*'|"(?:\\.|[^"\\])*")/g, '<span class="tok-str">$1</span>');
      html = html.replace(
        /\b(import|export|default|async|function|return|const|await|from|new|if)\b/g,
        '<span class="tok-kw">$1</span>'
      );
      html = html.replace(/\b([A-Z][a-zA-Z]+)\b/g, '<span class="tok-type">$1</span>');
      html = html.replace(/\b(GET|POST|Response|JSON)\b/g, '<span class="tok-fn">$1</span>');
      return html;
    };

    const finish = (text, withHighlight = true) => {
      if (withHighlight) {
        codeEl.innerHTML = highlight(text);
      } else {
        codeEl.textContent = text;
      }
      if (cursorEl) cursorEl.remove();
      codeArea.classList.add('is-typing-done');
    };

    let typingTimer = null;
    let charIndex = 0;
    let sourceText = codeMobile;

    const typeNext = () => {
      if (charIndex <= sourceText.length) {
        codeEl.textContent = sourceText.slice(0, charIndex);
        charIndex += 1;
        typingTimer = window.setTimeout(typeNext, 14);
      } else {
        finish(sourceText);
      }
    };

    const startTyping = () => {
      if (typingTimer) window.clearTimeout(typingTimer);
      charIndex = 0;
      sourceText = codeDesktop;
      codeArea.classList.remove('is-typing-done');
      if (cursorEl && !cursorEl.parentElement) {
        codeEl.insertAdjacentElement('afterend', cursorEl);
      }
      codeEl.textContent = '';
      typeNext();
    };

    const applyMode = () => {
      if (typingTimer) window.clearTimeout(typingTimer);
      if (!desktopMq.matches) {
        finish(codeMobile, true);
        return;
      }
      if (reducedMq.matches) {
        finish(codeDesktop, true);
        return;
      }
      startTyping();
    };

    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              applyMode();
              io.disconnect();
            }
          });
        },
        { threshold: 0.25 }
      );
      io.observe(codeArea);
    } else {
      applyMode();
    }

    desktopMq.addEventListener('change', applyMode);
    reducedMq.addEventListener('change', applyMode);
  })();
</script>

<script>
  (() => {
    const root = document.querySelector('.hero-terminal');
    const label = document.querySelector('[data-hero-status]');
    if (!root || !label) return;

    const sequence = [
      { phase: 'deployed', text: 'deployed', hold: 750 },
      { phase: 'building', text: 'building…', hold: 1100 },
      { phase: 'ready', text: 'ready', hold: 0 },
    ];

    const finish = () => {
      root.classList.remove('is-booting', 'is-fading');
      root.classList.add('is-ready');
      root.dataset.phase = 'ready';
      label.textContent = 'ready';
    };

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      finish();
      return;
    }

    let step = 0;

    const showStep = () => {
      const current = sequence[step];
      root.dataset.phase = current.phase;
      label.textContent = current.text;

      if (current.phase === 'ready') {
        finish();
        return;
      }

      step += 1;
      setTimeout(() => {
        root.classList.add('is-fading');
        setTimeout(() => {
          root.classList.remove('is-fading');
          showStep();
        }, 160);
      }, current.hold);
    };

    showStep();
  })();
</script>

<style>
  /* =========================================
     1. GLOBALE STRUKTUR & TYPOGRAFIE
     ========================================= */

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem; /* Mobil-Rand garantiert */
  }

  /* Einheitliche Header für ALLE Sektionen — Basis in style.css (.section-head, .section-title) */
  .section-head {
    margin-bottom: 5rem;
  }

  /* =========================================
     LEISTUNGEN
     ========================================= */

  .services {
    background-color: #0b1120;
    padding: clamp(5rem, 10vw, 8rem) 0;
    color: #fff;
  }

  .services .section-head {
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }

  .services-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    max-width: 1200px;
    margin-inline: auto;
    align-items: stretch;
  }

  .service-card {
    position: relative;
    display: flex;
    flex-direction: column;
    height: 100%;
    min-height: 18.5rem;
    align-items: stretch;
    text-align: left;
    padding: clamp(1.25rem, 3vw, 1.6rem);
    padding-top: clamp(1.5rem, 3.5vw, 1.85rem);
    border-radius: 14px;
    overflow: hidden;
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.06) 0%, rgba(255, 255, 255, 0.02) 42%, transparent 100%),
      rgba(15, 23, 42, 0.65);
    border: 1px solid rgba(255, 255, 255, 0.07);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.07),
      0 12px 32px rgba(0, 0, 0, 0.28);
    transition:
      transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1),
      border-color 0.4s ease,
      box-shadow 0.4s ease;
  }

  .service-card::before {
    content: '';
    position: absolute;
    inset: 0;
    padding: 1px;
    background: linear-gradient(
      165deg,
      rgba(16, 185, 129, 0.22) 0%,
      transparent 38%,
      transparent 100%
    );
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0.5;
    pointer-events: none;
    transition: opacity 0.4s ease;
    z-index: 1;
  }

  /* Bunte Top-Kante: Grün → ausblendend nach rechts (wie Tech-Stack-Karten) */
  .service-card::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, #10b981 0%, #38bdf8 55%, transparent 100%);
    opacity: 0.65;
    pointer-events: none;
    z-index: 3;
    box-shadow: 0 0 18px rgba(16, 185, 129, 0.28);
    transition: opacity 0.4s ease, box-shadow 0.4s ease;
  }

  .service-card:hover {
    transform: translateY(-5px);
    border-color: rgba(16, 185, 129, 0.22);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.1),
      0 20px 48px rgba(0, 0, 0, 0.4),
      0 0 0 1px rgba(16, 185, 129, 0.08);
  }

  .service-card:hover::before {
    opacity: 0.72;
  }

  .service-card:hover::after {
    opacity: 0.85;
    box-shadow: 0 0 22px rgba(16, 185, 129, 0.38);
  }

  .service-card__num {
    position: absolute;
    top: 0.35rem;
    right: 0.5rem;
    z-index: 2;
    font-size: clamp(3.5rem, 10vw, 4.5rem);
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.06em;
    color: transparent;
    -webkit-text-stroke: 1px rgba(16, 185, 129, 0.12);
    pointer-events: none;
    user-select: none;
  }

  .service-card__head,
  .service-card__body,
  .service-card__chips {
    position: relative;
    z-index: 2;
  }

  .service-card__head {
    width: 100%;
    flex-shrink: 0;
    margin-bottom: 0.85rem;
    padding-bottom: 0.65rem;
  }

  .service-card__head::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    right: calc(0.5rem + clamp(3.2rem, 9vw, 4.2rem) + 0.65rem);
    height: 1px;
    background: rgba(255, 255, 255, 0.06);
  }

  .service-card__path {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    margin: 0;
    min-height: 1.15rem;
    font-family: ui-monospace, 'Cascadia Code', monospace;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: #64748b;
    text-transform: lowercase;
  }

  .service-card__prompt {
    color: #10b981;
    font-weight: 700;
  }

  .service-card__body {
    flex: 1;
    display: flex;
    flex-direction: column;
    width: 100%;
    min-height: 0;
  }

  .service-card h3 {
    position: relative;
    z-index: 1;
    margin: 0 0 0.6rem;
    padding-right: 2rem;
    min-height: 2.75em;
    font-size: clamp(1.05rem, 2.2vw, 1.28rem);
    font-weight: 800;
    line-height: 1.25;
    color: #f8fafc;
    letter-spacing: -0.03em;
  }

  .service-card__text {
    position: relative;
    z-index: 1;
    flex: 1;
    margin: 0;
    font-size: clamp(0.88rem, 1.7vw, 0.96rem);
    line-height: 1.62;
    color: #94a3b8;
  }

  .service-card__chips {
    position: relative;
    z-index: 1;
    display: flex;
    flex-wrap: nowrap;
    gap: 0.35rem;
    width: 100%;
    min-height: 1.85rem;
