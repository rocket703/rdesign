---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';
import { faqItems } from '../data/faq';
import { homePageSchema, SITE } from '../lib/seo';

const allProjects = await getCollection('projects');

const featuredSlugs = ['startplatzboerse', 'ohrelauf', 'radsportclub-magdeburg'];
const featuredProjects = featuredSlugs
  .map((slug) => allProjects.find((project) => project.id.replace('.md', '') === slug))
  .filter((project): project is (typeof allProjects)[number] => Boolean(project));

const codeMobile = `async function ship(site) {
  await site.optimizeAssets();
  await site.prerender();
  return site.deploy({ edge: true });
}`;

const codeDesktop = `/**
 * Hybrid-Setup: schnelle Landingpages + SSR-API
 */
import { defineConfig } from 'astro/config';
import vercel from '@astrojs/vercel/serverless';

export default defineConfig({
  output: 'hybrid',
  adapter: vercel(),
  image: {
    service: { entrypoint: './image-service.ts' },
  },
  vite: {
    build: {
      cssMinify: 'lightningcss',
    },
  },
});

export async function GET({ cookies, redirect }) {
  const session = cookies.get('session')?.value;
  if (!session) return redirect('/login');

  const projects = await db
    .from('projects')
    .select('id, title, status')
    .order('updated_at', { ascending: false });

  return new Response(JSON.stringify(projects.data), {
    status: 200,
    headers: {
      'Content-Type': 'application/json',
      'Cache-Control': 'private, no-store',
    },
  });
}`;
---

<BaseLayout
  title={SITE.defaultTitle}
  description={SITE.defaultDescription}
  jsonLd={homePageSchema(faqItems, Astro.site)}
>
