---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');

const codeExample = `
function optimize(project) {
  project.assets.forEach(asset => {
    asset.compress();
    asset.lazyLoad();
  });
  return "100% Performance";
}
`;
---

<BaseLayout 
  title="r³webdesign – Webentwicklung, Design & Appentwicklung"
  description="r³webdesign entwickelt performante Webseiten, klares Design und smarte Apps."
>
 <section id="intro" class="section intro">
  <div class="hero-stack">
    <div class="hero-card card-1"></div>
    <div class="hero-card card-2"></div>
    <div class="hero-card card-3"></div>
    <div class="hero-card card-4"></div>
  </div>

  <div class="section-head">
    
    <!-- LOTTIE CAT -->
    <div class="r3-pure-cat">
      <div id="cat"></div>
    </div>

    <h1 class="r3-logo">
      <span class="r3-word">
        <span class="r3-r">r</span>
        <span class="r3-badge">3</span>
        <span class="r3-rest">webdesign</span>
      </span>
    </h1>
  </div>
</section>

 <section id="about" class="about">
    <div class="container about-container">
      <div class="about__inner">
        <figure class="about__media">
          <div class="image-glow"></div>
          <img src="/images/IMG_1907.webp" alt="Dustin Rose" width="320" height="320" loading="lazy" />
        </figure>
        
        <div class="about__content">
          <span class="eyebrow">Über mich</span>
          <p class="about__lead">
            Hi, ich bin <span class="text-gradient">Dustin</span>.
          </p>
          <h3 class="about__subline">Webentwickler & UI/UX Designer.</h3>
          
          <div class="about__text">
            <p>Ich baue keine 08/15-Webseiten. Ich entwickle digitale Erlebnisse, die schnell, barrierefrei und ästhetisch präzise sind.</p>
            <p>Ob Landingpage, Portfolio oder komplexe Web-App: Ich übersetze deine Vision in sauberen Code, der Unternehmen sichtbar macht.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section dev-showcase">
    <div class="container">
      <div class="section-head autoShow">
        <span class="eyebrow">Technical Stack</span>
        <h2 class="section-title">Engineering trifft <br/> modernes Design</h2>
        <div class="title-divider"></div>
        <p class="section-lead">
          Ich entwickle nicht nur Webseiten, ich baue digitale Hochleistungs-Systeme. 
          Von der Architektur bis zur Animation: Jede Zeile Code ist auf Skalierbarkeit und Speed getrimmt.
        </p>
      </div>
      
      <div class="skill-grid">
        <div class="skill-card primary">
          <div class="card-tag">Performance</div>
          <h3>Blitzschnell & Optimiert</h3>
          <p>
            Maximale Ladezeiten für beste User Experience. Dein Erfolg beginnt mit Geschwindigkeit.
          </p>
        </div>

        <div class="skill-card secondary">
          <div class="card-tag">Clean Code</div>
          <h3>Modular & Sicher</h3>
          <p>
            Strukturierter Code für einfache Wartbarkeit. Dein Projekt wächst problemlos mit dir.
          </p>
        </div>

        <div class="skill-card dynamic-cube">
          <div class="cube-wrapper">
            <div class="cube">
              <div class="face front">Astro</div>
              <div class="face back">HTML</div>
              <div class="face right">CSS</div>
              <div class="face left">JS</div>
              <div class="face top">SEO</div>
              <div class="face bottom">DB</div>
            </div>
          </div>
        </div>

        <div class="skill-card code-window">
          <div class="window-header">
            <div class="dot-group">
              <span class="dot red"></span>
              <span class="dot yellow"></span>
              <span class="dot green"></span>
            </div>
            <span class="filename">optimizer.js</span>
          </div>
          <div class="code-area">
            <pre><code class="language-javascript">{codeExample}</code></pre>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="projekte" class="section projects">
    <div class="section-head autoShow">
      <span class="eyebrow">Ausgewählte Referenzen</span>
      <h2 class="section-title">Digitale Wertschöpfung <br/> aus Sachsen-Anhalt</h2>
      <div class="title-divider"></div>
      <p class="section-lead">
        Maßgeschneiderte Web-Lösungen, die Performance mit Ästhetik vereinen. 
        Kein Standard, sondern digitales Handwerk für messbaren Erfolg.
      </p>
    </div>
    <div class="card-grid">
      {allProjects.map((project) => (
        <ProjectCard 
  title={project.data.title}
  description={project.data.subtitle}
  image={project.data.image}
  tags={project.data.techStack}
  id={project.id.replace('.md', '')}
/>
      ))}
    </div>
  </section>
</BaseLayout>

<script type="module">
  import lottie from "https://cdn.jsdelivr.net/npm/lottie-web@5.12.2/+esm";

  console.log("Script loaded");

  const container = document.getElementById("cat");
  console.log("Container:", container);

  if (container) {
    // 1. Die Animation in einer Konstante speichern
    const anim = lottie.loadAnimation({
      container: container,
      renderer: "canvas",
      loop: true,
      autoplay: false, // 2. Autoplay zwingend auf false setzen!
      path: "/animations/cat.json",
      rendererSettings: {
        clearCanvas: true,
      }
    });

    // 3. Warten, bis die Animationsdaten vollständig geladen sind
    anim.addEventListener('DOMLoaded', () => {
      // 4. Die exakte Hälfte der Gesamt-Frames berechnen
      const halbeFrames = anim.totalFrames / 2;
      
      // 5. Nur das Segment von Frame 0 bis zur Hälfte abspielen (true erzwingt den Start)
      anim.playSegments([0, halbeFrames], true);
    });

    console.log("Lottie initialized");
  } else {
    console.log("Container NOT found");
  }
</script>

<style>
  /* =========================================
     1. GLOBALE STRUKTUR & TYPOGRAFIE
     ========================================= */

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem; /* Mobil-Rand garantiert */
  }

  /* Einheitliche Header für ALLE Sektionen */
  .section-head {
    text-align: center;
    max-width: 900px;
    margin: 0 auto 5rem auto;
  }

  .eyebrow {
    color: #10b981;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    font-weight: 800;
    font-size: 0.85rem;
    display: block;
    margin-bottom: 1.2rem;
  }

  /* Einheitliche Überschriftengröße */
  .section-title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    line-height: 1.1;
    font-weight: 900;
    letter-spacing: -0.03em;
    margin-bottom: 1.5rem;
    color: #fff;
  }

  .title-divider {
    width: 80px;
    height: 4px;
    background: linear-gradient(90deg, #10b981, #059669);
    margin: 2rem auto;
    border-radius: 4px;
  }

  .section-lead {
    font-size: clamp(1.1rem, 2vw, 1.25rem);
    color: #94a3b8;
    line-height: 1.7;
    max-width: 750px;
    margin: 0 auto;
  }

  @media (max-width: 600px) {
    .section-title br { display: none; }
  }

  /* =========================================
     2. DEV SHOWCASE SEKTION (Tech Stack)
     ========================================= */

  .dev-showcase {
    background: #0b1120;
    padding: 8rem 0;
    color: #fff;
  }

  /* --- GRID LAYOUT --- */
  .skill-grid {
    display: grid;
    grid-template-columns: 1fr; /* Mobil: Alles untereinander */
    gap: 2rem;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* DESKTOP LAYOUT: 3 kleine Karten links, Code rechts */
  @media (min-width: 1024px) {
    .skill-grid {
      grid-template-columns: 1fr 1.5fr; 
      grid-template-rows: auto auto auto; 
      gap: 2rem;
      padding: 0;
    }

    /* Links: Die 3 kleinen Karten stapeln sich */
    .primary {
      grid-column: 1 / 2;
      grid-row: 1 / 2;
    }

    .secondary {
      grid-column: 1 / 2;
      grid-row: 2 / 3;
    }

    .dynamic-cube {
      grid-column: 1 / 2;
      grid-row: 3 / 4;
    }

    /* Rechts: Das Code-Fenster über die volle Höhe */
    .code-window {
      grid-column: 2 / 3;
      grid-row: 1 / 4;
      height: 100%;
    }
  }

  /* KARTEN DESIGN */
  .skill-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    padding: 2.5rem;
    transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
    backdrop-filter: blur(10px);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .skill-card:hover {
    transform: translateY(-5px);
    border-color: #10b981;
    background: rgba(255, 255, 255, 0.06);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
  }

  .card-tag {
    color: #10b981;
    font-weight: 800;
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 2px;
    margin-bottom: 1rem;
    display: inline-block;
  }

  .skill-card h3 {
    font-size: 1.8rem;
    font-weight: 800;
    margin-bottom: 1rem;
    color: #fff;
  }

  .skill-card p {
    color: #94a3b8;
    line-height: 1.6;
  }

  /* CODE WINDOW */
  .code-window {
    background: #011627 !important;
    padding: 0 !important;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.1) !important;
    display: flex;
    flex-direction: column;
  }

  .window-header {
    background: rgba(255, 255, 255, 0.05);
    padding: 1rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid rgba(0, 0, 0, 0.5);
  }

  .dot-group { 
    display: flex; 
    gap: 8px; 
  }

  .dot { 
    width: 12px; 
    height: 12px; 
    border-radius: 50%; 
  }

  .red { background: #ff5f56; } 
  .yellow { background: #ffbd2e; } 
  .green { background: #27c93f; }

  .filename { 
    font-size: 0.8rem; 
    color: #607b96; 
    font-family: 'Fira Code', monospace; 
  }

  .code-area {
    padding: 2rem;
    font-family: 'Fira Code', monospace;
    font-size: 0.9rem;
    line-height: 1.6;
    overflow-x: auto;
    flex-grow: 1;
  }

  .code-area code { 
    color: #addb67; 
  }

  /* --- MOBILE ANPASSUNG FÜR DAS CODE-FENSTER --- */
@media (max-width: 768px) {
  .code-window {
    width: 100%;
    max-width: 100vw; /* Zwingt das Fenster, strikt im Bildschirm zu bleiben */
    box-sizing: border-box;
    margin: 0 auto; /* Zentriert es sauber */
  }

  .window-header {
    padding: 0.75rem 1rem; /* Etwas kompakter, spart wertvollen Platz */
  }

  .dot {
    /* [PUNKTE_KLEINER] */
    width: 10px; 
    height: 10px;
  }

  .filename {
    font-size: 0.7rem; /* Dateiname dezent verkleinert */
  }

  .code-area {
    padding: 1rem; /* Padding halbiert: Gibt dem Code 2rem mehr Platz zum Atmen */
    font-size: 0.75rem; /* Die Schrift "ein müh" kleiner */
  }
}

  /* --- CUBE FIX --- */
.dynamic-cube {
  min-height: 300px;
  align-items: center;
  perspective: 1000px;
  overflow: visible;
}

.cube-wrapper {
  width: 80px;
  height: 80px;
  transform-style: preserve-3d;
  /* Optimierte Rotation für flüssigeren Ablauf */
  animation: rotateCube 20s infinite linear;
}

.cube { 
  position: relative; 
  width: 100%; 
  height: 100%; 
  transform-style: preserve-3d; 
}

.face {
  position: absolute; 
  width: 80px; 
  height: 80px;
  /* Etwas mehr Deckkraft (0.15) für bessere Lesbarkeit */
  background: rgba(16, 185, 129, 0.15); 
  border: 1px solid #10b981;
  display: flex; 
  align-items: center; 
  justify-content: center;
  font-weight: 800; 
  font-size: 0.8rem; 
  color: #fff;
  box-shadow: 0 0 25px rgba(16, 185, 129, 0.2);
  
  backface-visibility: hidden;
  -webkit-backface-visibility: hidden;
}

.front  { transform: translateZ(40px); }
.back   { transform: rotateY(180deg) translateZ(40px); } 
.right  { transform: rotateY(90deg) translateZ(40px); }
.left   { transform: rotateY(-90deg) translateZ(40px); }
.top    { transform: rotateX(90deg) translateZ(40px); }
.bottom { transform: rotateX(-90deg) translateZ(40px); }

@keyframes rotateCube {
  0% { transform: rotateX(0deg) rotateY(0deg); }
  100% { transform: rotateX(360deg) rotateY(360deg); }
}

  /* =========================================
     3. PROJEKTE SEKTION
     ========================================= */

  .projects {
    background-color: #0b1120;
    padding: 8rem 0;
  }

  .card-grid {
    display: grid;
    grid-template-columns: 1fr; /* Mobil: 1 Spalte */
    gap: 3rem;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem; /* Rand mobil */
  }

  @media (min-width: 768px) {
    .card-grid {
      grid-template-columns: repeat(2, 1fr); /* Tablet: 2 Spalten */
      padding: 0;
    }
  }

  @media (min-width: 1024px) {
    .card-grid {
      grid-template-columns: repeat(3, 1fr); /* Desktop: 3 Spalten */
    }
  }

  /* =========================================
     ABOUT SEKTION 
     ========================================= */

  .about {
    background-color: #0b1120;
    padding: 10rem 0;
    position: relative;
    overflow: hidden;
  }

  /* Subtiler Hintergrund-Schein hinter der Sektion */
  .about::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 0;
    width: 300px;
    height: 300px;
    background: rgba(16, 185, 129, 0.05); /* Sehr dezentes Grün */
    filter: blur(100px);
    border-radius: 50%;
    transform: translate(-50%, -50%);
    z-index: 0;
  }

  .about-container {
    position: relative;
    z-index: 1;
  }

  .about__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4rem;
  }

  /* --- DAS BILD --- */
  .about__media {
    position: relative;
    width: 280px;
    height: 280px;
    margin: 0;
    flex-shrink: 0;
  }

  .about__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    border: 1px solid #0b1120; 
    position: relative;
    z-index: 2;
    /* Ein sanfter Schatten für Tiefe */
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5);
  }

  /* Der Glow-Ring hinter dem Bild */
  .image-glow {
    position: absolute;
    inset: -10px; /* 10px größer als das Bild */
    border-radius: 50%;
    background: linear-gradient(135deg, #10b981, #059669);
    filter: blur(20px);
    opacity: 0.4;
    z-index: 1;
    animation: pulseGlow 4s ease-in-out infinite;
  }

  @keyframes pulseGlow {
    0%, 100% { transform: scale(1); opacity: 0.4; }
    50% { transform: scale(1.05); opacity: 0.6; }
  }

  /* --- DER TEXT --- */
  .about__content {
    text-align: center;
    max-width: 600px;
  }

  .about__lead {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    line-height: 1.1;
    color: #fff;
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
  }

  /* Gradient Text Effekt für "Dustin Rose" */
  .text-gradient {
    background: linear-gradient(90deg, #fff 0%, #cbd5e1 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    /* Optional: Ein Hauch Grün im Verlauf */
    background: linear-gradient(to right, #ffffff, #10b981); 
    -webkit-background-clip: text;
  }

  .about__subline {
    font-size: 1.25rem;
    color: #10b981;
    font-weight: 600;
    margin-bottom: 2rem;
    font-family: monospace; /* Tech-Vibe */
  }

  .about__text p {
    color: #94a3b8;
    line-height: 1.8;
    font-size: 1.1rem;
    margin-bottom: 1.5rem;
  }

  .about__text p:last-child {
    margin-bottom: 0;
  }

  /* --- DESKTOP LAYOUT --- */
  @media (min-width: 900px) {
    .about__inner {
      flex-direction: row; /* Nebeneinander */
      justify-content: center;
      align-items: center; /* Vertikal zentriert */
      text-align: left; /* Text linksbündig */
      gap: 6rem; /* Viel Platz dazwischen */
    }

    .about__content {
      text-align: left;
    }

    .about__media {
      width: 320px;
      height: 320px;
    }
  }
   /* =========================================
     HERO SEKTION 
     ========================================= */

    #intro {
  position: relative;
  background-color: #05080a; /* Extrem dunkles Fundament */
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

/* --- 1. GRUND-SETUP (Gilt für alle Bildschirme) --- */
.hero-stack {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 0;
}

.hero-card {
  position: absolute;
  border-radius: 30px;
  box-shadow: -10px 10px 30px rgba(0, 0, 0, 0.5);
}

/* --- 2. DESKTOP LOOK (Breite Bildschirme) --- */
@media (min-width: 769px) {
  .hero-card {
    width: 60vw;
    height: 80vh;
  }
  .card-1 { 
    background: linear-gradient(135deg, #064e3b 0%, #05080a 100%); 
    transform: translate(-25%, -10%) rotate(-15deg); 
    z-index: 1; 
  }
  .card-2 { 
    background: linear-gradient(135deg, #065f46 0%, #05080a 100%); 
    transform: translate(-12%, -5%) rotate(-10deg); 
    z-index: 2; 
  }
  .card-3 { 
    background: linear-gradient(135deg, #0f766e 0%, #05080a 100%); 
    transform: translate(0%, 0%) rotate(-5deg); 
    z-index: 3; 
    opacity: 0.9; 
  }
  .card-4 { 
    background: linear-gradient(135deg, #10b981 0%, #05080a 100%); 
    transform: translate(12%, 5%) rotate(0deg); 
    z-index: 4; 
    opacity: 0.4; 
  }
}

/* --- 3. MOBIL LOOK (Smartphones wie das S24) --- */
@media (max-width: 768px) {
  .hero-card {
    width: 75vw;
    height: 45vh; 
    max-height: 380px; /* Verhindert extreme Streckung */
    border-radius: 24px;
  }
  .card-1 { 
    background: linear-gradient(135deg, #064e3b 0%, #05080a 100%);
    transform: translate(-12%, -10%) rotate(-14deg); 
    z-index: 1; 
  }
  .card-2 { 
    background: linear-gradient(135deg, #065f46 0%, #05080a 100%);
    transform: translate(-4%, -5%) rotate(-7deg); 
    z-index: 2; 
  }
  .card-3 { 
    background: linear-gradient(135deg, #0f766e 0%, #05080a 100%);
    transform: translate(4%, 0%) rotate(0deg); 
    z-index: 3; 
    opacity: 0.9;
  }
  .card-4 { 
    background: linear-gradient(135deg, #10b981 0%, #05080a 100%);
    transform: translate(12%, 5%) rotate(7deg); 
    z-index: 4; 
    opacity: 0.3; 
  }

  /* Etwas Luft für das Logo auf kleinen Screens */
  .r3-logo {
    transform: scale(0.85); 
  }
}

/*==========================================
   KATZE
   =========================================*/

 /* Standard / Desktop (dein bisheriger Code zusammengefasst) */
.r3-pure-cat {
  position: absolute;
  top: -145px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 100;
  pointer-events: none;
  width: 100%;
  height: 100%;
}

/* Mobile Anpassung (für Bildschirme bis 768px Breite) */
@media (max-width: 768px) {
  .r3-pure-cat {
    top: -108px;
    
  }
}
/* =========================================
   SUBTLE BUBBLES
   ========================================= */

.subtle-bubbles {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 0;
  overflow: hidden;
}

.subtle-bubble {
  position: absolute;
  bottom: -10px;
  border-radius: 50%;
  background: rgba(16, 185, 129, 0.15);
  border: 1px solid rgba(16, 185, 129, 0.2);
  animation: bubbleRise linear infinite;
}

@keyframes bubbleRise {
  0% {
    transform: translateY(0) translateX(0);
    opacity: 0;
  }
  10% {
    opacity: 0.6;
  }
  90% {
    opacity: 0.3;
  }
  100% {
    transform: translateY(-100vh) translateX(var(--drift));
    opacity: 0;
  }
}
</style>