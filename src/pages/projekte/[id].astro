---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import {
  breadcrumbSchema,
  creativeWorkSchema,
  schemaGraph,
  webPageSchema,
} from '../../lib/seo';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { id: project.id.replace('.md', '') },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const projectLink = project.data.customerUrl;
const projectStatus = project.data.status;
const title = project.data.title;
const hasSpace = title.trim().includes(' ');
const projectSlug = project.id.replace('.md', '');
const projectPath = `/projekte/${projectSlug}`;
const pageTitle = project.data.seoTitle ?? `${project.data.title} | r³webdesign`;
const pageDescription = project.data.seoDesc ?? project.data.subtitle;
const liveHost = (() => {
  try {
    return new URL(projectLink).hostname.replace(/^www\./, '');
  } catch {
    return null;
  }
})();
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  image={project.data.image}
  jsonLd={schemaGraph([
    webPageSchema({
      name: pageTitle,
      description: pageDescription,
      pathname: projectPath,
      site: Astro.site,
    }),
    breadcrumbSchema(
      [
        { name: 'Start', path: '/' },
        { name: 'Projekte', path: '/projekte/' },
        { name: project.data.title, path: projectPath },
      ],
      Astro.site,
    ),
    creativeWorkSchema({
      title: project.data.title,
      description: pageDescription,
      image: project.data.image,
      pathname: projectPath,
      liveUrl: projectLink,
      keywords: project.data.techStack,
      site: Astro.site,
    }),
  ])}
>
  <article class="project-detail-view">
    <div class="main-container">

      <nav class="project-nav" aria-label="Projektnavigation">
        <a href="/projekte/" class="project-back">
          <span class="project-back__prompt" aria-hidden="true">&gt;_</span>
          <span>zurück.projekte</span>
        </a>
      </nav>

      <header class="project-hero">
        <p class="project-path project-hero__path">
          <span class="project-prompt">&gt;_</span>
          <span>proj.{projectSlug}</span>
        </p>
        <h1 class={`section-title project-hero__title ${!hasSpace ? 'is-single-word' : ''}`}>
          {project.data.title}
        </h1>
        <div class="title-divider"></div>
        <p class="section-lead project-hero__lead">{project.data.subtitle}</p>

        {project.data.techStack?.length ? (
          <ul class="project-tags" aria-label="Technologien">
            {project.data.techStack.map((tag) => (
              <li>{tag}</li>
            ))}
          </ul>
        ) : null}
      </header>

      <section class="project-showcase" aria-label="Projektvorschau">
        <a href={projectLink} target="_blank" rel="noopener noreferrer" class="project-showcase__link">
          <div class="project-showcase__frame">
            <img src={project.data.image} alt={`Vorschau: ${project.data.title}`} loading="lazy" decoding="async" />
          </div>
          <span class="project-showcase__hint">
            <span class="project-showcase__hint-prompt" aria-hidden="true">&gt;</span>
            Live-Seite öffnen
          </span>
        </a>
      </section>

      <div class="project-layout">
        <article class="project-panel project-panel--main">
          <p class="project-panel__path">
            <span class="project-prompt">&gt;_</span>
            <span>analysis.md</span>
          </p>
          <h2 class="project-panel__title">Projekt-Analyse</h2>
          <div class="project-prose">
            <Content />
          </div>
        </article>

        <aside class="project-panel project-panel--sidebar">
          <p class="project-panel__path">
            <span class="project-prompt">&gt;_</span>
            <span>meta.json</span>
          </p>
          <dl class="project-facts">
            <div class="project-facts__row">
              <dt>Status</dt>
              <dd>{projectStatus}</dd>
            </div>
            {project.data.techStack?.length ? (
              <div class="project-facts__row">
                <dt>Stack</dt>
                <dd>{project.data.techStack.slice(0, 4).join(' · ')}{project.data.techStack.length > 4 ? ' …' : ''}</dd>
              </div>
            ) : null}
            {liveHost ? (
              <div class="project-facts__row">
                <dt>Live</dt>
                <dd><a href={projectLink} target="_blank" rel="noopener noreferrer">{liveHost}</a></dd>
              </div>
            ) : null}
            <div class="project-facts__row">
              <dt>Ort</dt>
              <dd>Magdeburg · remote</dd>
            </div>
          </dl>
          <p class="project-panel__note">Interesse an einer ähnlichen Umsetzung?</p>
          <a href={projectLink} target="_blank" rel="noopener noreferrer" class="project-cta">
            <span class="project-cta__prompt" aria-hidden="true">&gt;</span>
            Webseite besuchen
          </a>
          <a href="/kontakt/" class="project-cta project-cta--ghost">
            <span class="project-cta__prompt" aria-hidden="true">&gt;</span>
            Projekt anfragen
          </a>
        </aside>
      </div>

    </div>
  </article>
</BaseLayout>

<style>
  .project-detail-view {
    background-color: #0b1120;
    color: #fff;
    min-height: 100vh;
    padding: clamp(1.5rem, 4vw, 2.5rem) 0 clamp(5rem, 10vw, 8rem);
  }

  .main-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .project-nav {
    margin-bottom: clamp(1.5rem, 4vw, 2.5rem);
  }

  .project-back {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: ui-monospace, 'Cascadia Code', monospace;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: lowercase;
    text-decoration: none;
    color: #94a3b8;
    transition: color 0.2s ease;
  }

  .project-back__prompt {
    color: #10b981;
    font-weight: 700;
  }

  .project-back:hover {
    color: #ecfdf5;
  }

  .project-hero {
    text-align: center;
    max-width: 900px;
    margin: 0 auto clamp(3rem, 6vw, 4.5rem);
    padding: 0 0.25rem;
    background: none;
  }

  .project-hero__path {
    justify-content: center;
    margin-bottom: 1rem;
  }

  .project-hero__title {
    margin-bottom: 0;
  }

  .project-hero__title.is-single-word {
    white-space: nowrap;
    font-size: clamp(1.1rem, 7.5vw, 5.5rem);
    overflow: hidden;
    text-overflow: ellipsis;
  }

  @media (min-width: 1024px) {
    .project-hero__title.is-single-word {
      font-size: clamp(2.5rem, 6vw, 4rem);
      white-space: normal;
      overflow: visible;
      text-overflow: unset;
    }
  }

  .project-hero__lead {
    margin-top: 0;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
    margin: clamp(1.75rem, 4vw, 2.25rem) 0 0;
    padding: 0;
    list-style: none;
  }

  .project-tags li {
    font-family: ui-monospace, 'Cascadia Code', monospace;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #cbd5e1;
    padding: 0.32rem 0.65rem;
    border-radius: 4px;
    background: rgba(0, 0, 0, 0.35);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .project-showcase {
    margin-bottom: clamp(3rem, 7vw, 5rem);
  }

  .project-showcase__link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .project-showcase__frame {
    position: relative;
    overflow: hidden;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 14px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(11, 17, 32, 0.9);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.06),
      0 18px 40px rgba(0, 0, 0, 0.35);
    transition: transform 0.35s cubic-bezier(0.2, 0.8, 0.2, 1), border-color 0.35s ease;
  }

  .project-showcase__frame::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--accent-lime) 0%, #10b981 35%, #38bdf8 70%, transparent 100%);
    opacity: 0.75;
    z-index: 1;
    pointer-events: none;
  }

  .project-showcase__frame img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    transition: transform 0.45s cubic-bezier(0.2, 1, 0.3, 1);
  }

  .project-showcase__link:hover .project-showcase__frame {
    transform: translateY(-6px);
    border-color: rgba(16, 185, 129, 0.25);
  }

  .project-showcase__link:hover .project-showcase__frame img {
    transform: scale(1.03);
  }

  .project-showcase__hint {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.85rem;
    font-family: ui-monospace, monospace;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: lowercase;
    color: #64748b;
    transition: color 0.2s ease;
  }

  .project-showcase__hint-prompt {
    color: #10b981;
  }

  .project-showcase__link:hover .project-showcase__hint {
    color: #94a3b8;
  }

  .project-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.5rem, 4vw, 2rem);
    align-items: start;
  }

  @media (min-width: 900px) {
    .project-layout {
      grid-template-columns: minmax(0, 1.65fr) minmax(260px, 0.85fr);
      gap: clamp(1.5rem, 3vw, 2rem);
    }
  }

  .project-panel {
    position: relative;
    overflow: hidden;
    padding: clamp(1.35rem, 3vw, 1.85rem);
    border-radius: 14px;
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.06) 0%, rgba(255, 255, 255, 0.02) 42%, transparent 100%),
      rgba(15, 23, 42, 0.65);
    border: 1px solid rgba(255, 255, 255, 0.07);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.07),
      0 12px 32px rgba(0, 0, 0, 0.28);
  }

  .project-panel::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--accent-lime) 0%, #10b981 35%, #38bdf8 70%, transparent 100%);
    opacity: 0.75;
    pointer-events: none;
  }

  .project-panel__path {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    margin: 0 0 1rem;
    font-family: ui-monospace, 'Cascadia Code', monospace;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: lowercase;
    color: #64748b;
  }

  .project-panel__title {
    margin: 0 0 1.25rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    font-size: clamp(1.35rem, 3vw, 1.65rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: #f3f4f6;
  }

  .project-prose {
    color: #94a3b8;
    font-size: clamp(1rem, 2vw, 1.08rem);
    line-height: 1.75;
  }

  .project-prose :global(p) {
    margin: 0 0 1.25rem;
  }

  .project-prose :global(p:last-child) {
    margin-bottom: 0;
  }

  .project-prose :global(strong) {
    color: #e2e8f0;
    font-weight: 700;
  }

  .project-prose :global(ul) {
    margin: 0 0 1.25rem;
    padding-left: 1.2rem;
    color: #94a3b8;
  }

  .project-prose :global(li) {
    margin-bottom: 0.45rem;
  }

  .project-panel--sidebar {
    text-align: center;
  }

  .project-panel--sidebar .project-facts {
    text-align: left;
  }

  @media (min-width: 900px) {
    .project-panel--sidebar {
      position: sticky;
      top: calc(var(--site-header-height) + 1rem);
    }
  }

  .project-facts {
    margin: 0 0 1.35rem;
    padding: 0 0 1.25rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    text-align: left;
  }

  .project-facts__row {
    display: grid;
    grid-template-columns: 4.5rem 1fr;
    gap: 0.65rem;
    align-items: baseline;
    margin-bottom: 0.65rem;
  }

  .project-facts__row:last-child {
    margin-bottom: 0;
  }

  .project-facts dt {
    margin: 0;
    font-family: ui-monospace, monospace;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #64748b;
  }

  .project-facts dd {
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.45;
    color: #cbd5e1;
  }

  .project-facts__row:first-child dd {
    text-transform: capitalize;
  }

  .project-facts dd a {
    color: #10b981;
    text-decoration: none;
    text-transform: lowercase;
    word-break: break-all;
  }

  .project-facts dd a:hover {
    text-decoration: underline;
  }

  .project-panel__note {
    margin: 0 0 1.25rem;
    color: #94a3b8;
    line-height: 1.6;
    font-size: 0.98rem;
  }

  .project-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.95rem 1.25rem;
    border-radius: 12px;
    font-size: 0.92rem;
    font-weight: 800;
    letter-spacing: 0.02em;
    text-decoration: none;
    color: #ecfdf5;
    background: rgba(16, 185, 129, 0.12);
    border: 1px solid rgba(16, 185, 129, 0.45);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.12),
      0 8px 28px rgba(16, 185, 129, 0.15);
    transition: transform 0.25s ease, background 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
  }

  .project-cta + .project-cta {
    margin-top: 0.75rem;
  }

  .project-cta__prompt {
    font-family: ui-monospace, monospace;
    color: #10b981;
    font-weight: 700;
  }

  .project-cta:hover {
    transform: translateY(-2px);
    background: rgba(16, 185, 129, 0.2);
    border-color: #34d399;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.15),
      0 14px 36px rgba(16, 185, 129, 0.28);
  }

  .project-cta--ghost {
    color: #cbd5e1;
    background: rgba(0, 0, 0, 0.25);
    border-color: rgba(255, 255, 255, 0.1);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }

  .project-cta--ghost:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(16, 185, 129, 0.3);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.08),
      0 10px 24px rgba(0, 0, 0, 0.25);
  }

  @media (max-width: 480px) {
    .project-hero__title.is-single-word {
      font-size: clamp(0.95rem, 7vw, 1.35rem);
    }
  }
</style>
