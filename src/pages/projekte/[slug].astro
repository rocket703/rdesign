---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();

// Zuweisung der Variablen aus deinem Markdown
const projectLink = project.data.customerUrl;
const projectStatus = project.data.status; // Zieht jetzt "online", "im aufbau", etc.

// Zwischen den --- ganz oben
const title = project.data.title;

// Logik: Hat der Titel ein Leerzeichen? 
// (Wichtig: Wir trimmen, falls aus Versehen Leerzeichen am Ende stehen)
const hasSpace = title.trim().includes(' ');
---

<BaseLayout title={`${project.data.title} | r³webdesign`} description={project.data.subtitle}>
  <article class="project-detail-view">
    <div class="main-container">
      
      <nav class="nav-top">
        <a href="/#projekte" class="back-link-custom">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
            <path d="M19 12H5M12 19l-7-7 7-7"/>
          </svg>
          <span>Übersicht</span>
        </a>
      </nav>

      <header class="hero-header">
  <h1 class={`headline-xl ${!hasSpace ? 'is-single-word' : ''}`}>
    {project.data.title}
  </h1>
  <p class="sub-headline">{project.data.subtitle}</p>
        
        <div class="tech-stack-flex">
          {project.data.techStack && project.data.techStack.map((tag) => (
            <span class="tech-badge-modern">{tag}</span>
          ))}
        </div>
      </header>

      <section class="image-showcase">
        <a href={projectLink} target="_blank" rel="noopener noreferrer" class="img-anchor">
          <div class="aspect-box">
            <img src={project.data.image} alt={project.data.title} />
          </div>
        </a>
      </section>

      <div class="content-layout">
        <main class="text-content prose">
          <h2 class="label-small">Projekt-Analyse</h2>
          <Content />
        </main>
        
        <aside class="sidebar-info">
          <div class="status-card-modern">
            <div class="status-wrap">
              <span class="status-pulse"></span>
              <span class="status-text">Status: {projectStatus}</span>
            </div>
            <p>Interesse an einer ähnlichen Performance?</p>
            <a href={projectLink} target="_blank" rel="noopener noreferrer" class="btn-direct">
              Webseite besuchen
            </a>
          </div>
        </aside>
      </div>

    </div>
  </article>
</BaseLayout>

<style>
  :root {
    --r3-green: #10b981;
    --navy-dark: #0b1120;
    --slate-400: #94a3b8;
    --glass-bg: rgba(255, 255, 255, 0.03);
  }

  .project-detail-view {
    background-color: var(--navy-dark);
    color: #ffffff;
    min-height: 100vh;
    padding: 2rem 0 10rem;
    font-family: 'Inter', sans-serif;
  }

  .main-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Back Link - No Decoration */
  .back-link-custom {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--r3-green);
    text-decoration: none !important;
    font-weight: 800;
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 1px;
  }

 .hero-header { 
    text-align: center; 
    margin: 3rem 0 4rem; 
    padding: 0 1rem;
    width: 100%;
  }

  /* LOGIK FÜR EINZELNE LANGE WÖRTER */
  .headline-xl.is-single-word {
    white-space: nowrap; /* Zwingt alles in eine Zeile */
    /* Wir gehen auf 7.5vw runter, damit auch 20+ Zeichen Platz haben */
    font-size: clamp(1rem, 7.5vw, 5.5rem); 
    display: block;
    width: 100%;
    overflow: hidden; /* Sicherheitshalber */
  }

  @media (max-width: 400px) {
    .headline-xl.is-single-word {
      /* Reißleine für winzige Handys */
      font-size: clamp(0.9rem, 7vw, 1.4rem);
    }
  }

  @media (min-width: 1024px) {
    .headline-xl {
      font-size: 5.5rem;
      letter-spacing: -4px;
      line-height: 0.9;
    }
    /* Auf Desktop darf auch ein einzelnes Wort wieder groß sein */
    .headline-xl.is-single-word {
      font-size: 5.5rem;
    }
  }
  
  /* Korrektur für extrem schmale Handys */
  @media (max-width: 400px) {
    .headline-xl.is-single-word {
      font-size: clamp(1rem, 7.5vw, 1.5rem);
    }
  }

  /* Tech-Stack Badges */
  .tech-stack-flex {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.8rem;
    max-width: 850px;
    margin: 0 auto;
  }

  .tech-badge-modern {
    background: var(--glass-bg);
    border: 1px solid rgba(16, 185, 129, 0.3);
    color: var(--r3-green);
    padding: 0.5rem 1.25rem;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  /* Image Aspect Ratio & Lift */
  .image-showcase { margin-bottom: 8rem; }
  .aspect-box {
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 40px 80px -20px rgba(0,0,0,0.7);
    transition: transform 0.5s cubic-bezier(0.2, 1, 0.3, 1);
  }
  .aspect-box img { width: 100%; height: 100%; object-fit: cover; }
  .img-anchor:hover .aspect-box { transform: translateY(-10px); }

  /* Layout Grid */
  .content-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 5rem;
  }

  @media (min-width: 900px) {
    .content-layout { grid-template-columns: 2fr 1fr; }
  }

  .label-small {
    color: var(--r3-green);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 3px;
    font-weight: 900;
    margin-bottom: 2rem;
  }

  .prose { font-size: 1.2rem; line-height: 1.8; color: var(--slate-400); }
  .prose :global(p) { margin-bottom: 2rem; }

  /* Sidebar Card */
  .status-card-modern {
    position: sticky;
    top: 4rem;
    background: var(--glass-bg);
    border: 1px solid rgba(255,255,255,0.05);
    padding: 3rem;
    border-radius: 16px;
    text-align: center;
  }

  .status-wrap {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: rgba(0,0,0,0.3);
    padding: 0.5rem 1.2rem;
    border-radius: 50px;
    margin-bottom: 2rem;
  }

  .status-pulse {
    width: 8px;
    height: 8px;
    background: var(--r3-green);
    border-radius: 50%;
    box-shadow: 0 0 12px var(--r3-green);
  }

  .status-text { font-size: 0.85rem; font-weight: 800; text-transform: capitalize; }

  .btn-direct {
    display: block;
    background: var(--r3-green);
    color: #fff;
    padding: 1.2rem;
    border-radius: 8px;
    text-decoration: none !important;
    font-weight: 800;
    transition: all 0.3s ease;
    margin-top: 2rem;
  }
  .btn-direct:hover { background: #059669; transform: scale(1.02); }
</style>
