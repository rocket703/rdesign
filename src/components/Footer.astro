---
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-body">
    <div class="footer-grid">
      <div class="item-left">
        <div class="status-badge">
          <span class="pulse-dot"></span>
          SYSTEM ONLINE
        </div>
      </div>
      <div class="item-center">
        <a href="/" class="f-logo">r³webdesign</a>
        <div class="f-slogan">
          <span class="cmd">></span> Code. Design. Performance<span class="cursor">_</span>
        </div>
      </div>
      <div class="item-right">
        <nav class="f-nav">
          <a href="/impressum">IMPRESSUM</a>
          <a href="/datenschutz">DATENSCHUTZ</a>
        </nav>
        <p class="f-copy">© {currentYear}</p>
      </div>
    </div>
  </div>

  <div class="footer-visual-bottom">
    <div class="huge-outline-text">
      r³webdesign
    </div>
  </div>
</footer>

<style>
  /* BASIS */
  .site-footer {
    background-color: #0b1120;
    width: 100%;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    display: flex;
    flex-direction: column;
    align-items: center;
    margin: 0;
    padding: 0;
  }

  /* INHALT-BEREICH */
  .footer-body {
    width: 100%;
    max-width: 1600px;
    padding: 6rem 2rem 4rem 2rem; /* Viel Platz nach oben, moderat nach unten */
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 2rem;
  }

  /* VISUELLER ABSCHLUSS (Hier wird geschnitten) */
  .footer-visual-bottom {
    width: 100%;
    position: relative;
    /* Wir definieren die Höhe der "Sichtfensters" auf genau 10vw */
    height: 10vw;
    overflow: hidden; /* DAS schneidet die Schrift jetzt unerbittlich ab */
    display: flex;
    justify-content: center;
    margin-bottom: -1px; /* Entfernt den Gap zum unteren Rand */
  }

  .huge-outline-text {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 15vw; /* Riesig auf Desktop */
    font-weight: 900;
    line-height: 1;
    color: transparent;
    -webkit-text-stroke: 2px rgba(16, 185, 129, 0.15);
    white-space: nowrap;
    text-transform: lowercase;
    /* Positionierung innerhalb des Sichtfensters */
    position: absolute;
    top: 0;
    /* Schrift nach oben rücken */
    transform: translateY(10%);
    pointer-events: none;
    user-select: none;
  }

  /* DESIGN ELEMENTE */
  .f-logo {
    font-size: 3rem;
    font-weight: 900;
    color: #fff;
    text-decoration: none;
    letter-spacing: -0.05em;
    transition: all 0.3s ease;
  }

  .f-logo:hover {
    color: #10b981;
    text-shadow: 0 0 30px rgba(16, 185, 129, 0.3);
  }

  .f-slogan {
    font-family: monospace;
    color: #10b981;
    margin-top: 0.5rem;
    font-size: 0.9rem;
  }

  .cmd {
    opacity: 0.6;
    margin-right: 5px;
  }

  .cursor {
    animation: blink 1s step-end infinite;
    font-weight: bold;
  }

  @keyframes blink {
    50% { opacity: 0; }
  }

  .item-center {
    text-align: center;
  }

  .item-left {
  display: flex;
  justify-content: left; /* Zentriert den Badge horizontal auf Desktop */
  align-items: center;
}
  .status-badge {
    display: flex;
    align-items: center;
    max-width: 200px;
    gap: 8px;
    font-family: monospace;
    font-size: 0.75rem;
    color: #64748b;
    border: 1px solid #334155;
    padding: 6px 14px;
    border-radius: 50px;
    transition: all 0.3s ease;
  }

  .status-badge:hover {
    border-color: #10b981;
    background: rgba(16, 185, 129, 0.05);
  }

  .pulse-dot {
    width: 8px;
    height: 8px;
    background: #10b981;
    border-radius: 50%;
    box-shadow: 0 0 10px #10b981;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .item-right {
    text-align: right;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .f-nav {
    display: flex;
    gap: 1.5rem;
    justify-content: flex-end;
  }

  .f-nav a {
    color: #94a3b8;
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 700;
    transition: all 0.3s ease;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .f-nav a:hover {
    color: #10b981;
    text-shadow: 0 0 10px rgba(16, 185, 129, 0.5);
  }

  .f-copy {
    color: #334155;
    font-size: 0.7rem;
    font-family: monospace;
  }

  /* =========================================
     MOBILE FIX
     ========================================= */

  @media (max-width: 1023px) {
    .footer-body {
      padding: 4rem 1rem 3rem 1rem;
    }

    .footer-grid {
      display: flex;
      flex-direction: column;
      gap: 3rem;
      text-align: center;
    }

    .item-right {
      text-align: center;
      align-items: center;
    }

    .f-nav {
      justify-content: center;
    }

    .footer-visual-bottom {
      height: 12vw; /* Mobil etwas mehr Sichtfenster */
    }

    .huge-outline-text {
      font-size: 16vw; /* Mobil etwas größer ziehen */
      -webkit-text-stroke: 1px rgba(16, 185, 129, 0.15);
      /* Mobile: andere Positionierung */
      transform: translateY(15%);
    }
  }

  /* =========================================
     SEHR KLEINE MOBILE GERÄTE
     ========================================= */

  @media (max-width: 600px) {
    .footer-body {
      padding: 3rem 0.75rem 2rem 0.75rem;
    }

    .f-logo {
      font-size: 2rem;
    }

    .f-slogan {
      font-size: 0.75rem;
    }

    .f-nav a {
      font-size: 0.75rem;
    }

    .footer-visual-bottom {
      height: 11vw;
    }

    .huge-outline-text {
      font-size: 14vw;
      transform: translateY(10%);
    }
  }
</style>
